{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API local (Docker DB)",
            "type": "pwa-node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--enable-source-maps",
                "--import",
                "tsx"
            ],
            "args": [
                "src/server.ts"
            ],
            "env": {
                "NODE_ENV": "development",
                "PORT": "3334",
                "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/barbup?schema=public",
                "JWT_SECRET": "barbup-local-secret",
                "JWT_EXPIRES_IN": "7d"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Attach API in Docker",
            "type": "pwa-node",
            "request": "attach",
            "address": "localhost",
            "port": 9229,
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app",
            "restart": true,
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node-terminal",
            "name": "Run Script: start",
            "request": "launch",
            "command": "npm run start",
            "cwd": "${workspaceFolder}"
        }
    ]
}