generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  BARBER
  CLIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ACCEPTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentMethod {
  PIX
  CREDIT
  DEBIT
  PAY_LATER
}

enum PaymentStatus {
  PENDING
  INFORMED
  PAID
  CANCELLED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  SERVICE_OVERRIDE
  TIME_WINDOW
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LoyaltyRuleType {
  VISIT_COUNT
  AMOUNT_SPENT
}

enum CampaignTargetType {
  ALL_CLIENTS
  ACTIVE_CLIENTS
  MEMBERSHIP_CLIENTS
  CUSTOM_GROUP
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  role           UserRole
  email          String          @unique @db.VarChar(255)
  passwordHash   String          @db.VarChar(255)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  clientProfile  ClientProfile?
  barberProfile  BarberProfile?
  campaignsSent  CampaignMessage[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model ClientProfile {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @db.Uuid
  firstName          String             @db.VarChar(120)
  lastName           String             @db.VarChar(120)
  cpf                String             @unique @db.VarChar(14)
  phone              String             @db.VarChar(20)
  photoUrl           String?            @db.VarChar(500)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments       Appointment[]      @relation("ClientAppointments")
  loyaltyEntries     LoyaltyEntry[]
  memberships        ClientMembership[]

  @@index([firstName, lastName])
  @@index([phone])
  @@map("client_profiles")
}

model BarberProfile {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @unique @db.Uuid
  displayName        String              @db.VarChar(160)
  photoUrl           String?             @db.VarChar(500)
  bio                String?             @db.Text
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments       Appointment[]       @relation("BarberAppointments")
  availabilities     BarberAvailability[]
  timeOffs           BarberTimeOff[]

  @@index([displayName])
  @@index([isActive])
  @@map("barber_profiles")
}

model Service {
  id                      String                @id @default(uuid()) @db.Uuid
  name                    String                @db.VarChar(160)
  description             String?               @db.Text
  price                   Decimal               @db.Decimal(10, 2)
  durationMinutes         Int
  isActive                Boolean               @default(true)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  appointmentServices     AppointmentService[]

  @@unique([name])
  @@index([isActive])
  @@index([durationMinutes])
  @@map("services")
}

model Appointment {
  id                      String                @id @default(uuid()) @db.Uuid
  clientId                String                @db.Uuid
  barberId                String                @db.Uuid
  startAt                 DateTime
  endAt                   DateTime
  status                  AppointmentStatus     @default(PENDING)
  paymentMethod           PaymentMethod
  paymentStatus           PaymentStatus         @default(PENDING)
  subtotalAmount          Decimal               @db.Decimal(10, 2)
  discountAmount          Decimal               @default(0) @db.Decimal(10, 2)
  totalAmount             Decimal               @db.Decimal(10, 2)
  notes                   String?               @db.Text
  whatsappMessage         String?               @db.Text
  whatsappMessageSentAt   DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  client                  ClientProfile         @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Restrict)
  barber                  BarberProfile         @relation("BarberAppointments", fields: [barberId], references: [id], onDelete: Restrict)
  services                AppointmentService[]
  loyaltyEntries          LoyaltyEntry[]

  @@index([clientId, startAt])
  @@index([barberId, startAt])
  @@index([barberId, startAt, endAt])
  @@index([status])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@map("appointments")
}

model AppointmentService {
  id                        String          @id @default(uuid()) @db.Uuid
  appointmentId             String          @db.Uuid
  serviceId                 String          @db.Uuid
  serviceNameSnapshot       String          @db.VarChar(160)
  unitPriceSnapshot         Decimal         @db.Decimal(10, 2)
  durationMinutesSnapshot   Int
  discountAmountSnapshot    Decimal         @default(0) @db.Decimal(10, 2)

  appointment               Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service                   Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
  @@index([serviceId])
  @@unique([appointmentId, serviceId])
  @@map("appointment_services")
}

model Promotion {
  id                String          @id @default(uuid()) @db.Uuid
  title             String          @db.VarChar(180)
  description       String?         @db.Text
  type              PromotionType
  value             Decimal         @db.Decimal(10, 2)
  startAt           DateTime
  endAt             DateTime
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([isActive])
  @@index([startAt, endAt])
  @@index([type])
  @@map("promotions")
}

model DiscountSchedule {
  id                String          @id @default(uuid()) @db.Uuid
  weekday           Weekday
  startTime         String          @db.VarChar(5)
  endTime           String          @db.VarChar(5)
  discountType      DiscountType
  discountValue     Decimal         @db.Decimal(10, 2)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([weekday, isActive])
  @@map("discount_schedules")
}

model LoyaltyProgram {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @db.VarChar(160)
  ruleType          LoyaltyRuleType
  targetCount       Int
  rewardDescription String            @db.Text
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([isActive])
  @@index([ruleType])
  @@map("loyalty_programs")
}

model LoyaltyEntry {
  id                String            @id @default(uuid()) @db.Uuid
  clientId          String            @db.Uuid
  appointmentId     String            @db.Uuid
  points            Int
  createdAt         DateTime          @default(now())

  client            ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment       Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId])
  @@index([clientId, createdAt])
  @@map("loyalty_entries")
}

model MembershipPlan {
  id                String              @id @default(uuid()) @db.Uuid
  name              String              @db.VarChar(160)
  monthlyPrice      Decimal             @db.Decimal(10, 2)
  description       String?             @db.Text
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  clientMemberships ClientMembership[]

  @@unique([name])
  @@index([isActive])
  @@map("membership_plans")
}

model ClientMembership {
  id                 String            @id @default(uuid()) @db.Uuid
  clientId           String            @db.Uuid
  membershipPlanId   String            @db.Uuid
  startDate          DateTime
  endDate            DateTime?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  client             ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  membershipPlan     MembershipPlan    @relation(fields: [membershipPlanId], references: [id], onDelete: Restrict)

  @@index([clientId, isActive])
  @@index([membershipPlanId, isActive])
  @@map("client_memberships")
}

model Product {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @db.VarChar(160)
  description       String?           @db.Text
  price             Decimal           @db.Decimal(10, 2)
  imageUrl          String?           @db.VarChar(500)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([name])
  @@index([isActive])
  @@map("products")
}

model CampaignMessage {
  id                String              @id @default(uuid()) @db.Uuid
  title             String              @db.VarChar(180)
  content           String              @db.Text
  targetType        CampaignTargetType
  createdByUserId   String              @db.Uuid
  createdAt         DateTime            @default(now())

  createdByUser     User                @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([targetType])
  @@index([createdByUserId, createdAt])
  @@map("campaign_messages")
}

model BarberAvailability {
  id                String            @id @default(uuid()) @db.Uuid
  barberId          String            @db.Uuid
  weekday           Weekday
  startTime         String            @db.VarChar(5)
  endTime           String            @db.VarChar(5)
  isActive          Boolean           @default(true)

  barber            BarberProfile     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, weekday, isActive])
  @@map("barber_availabilities")
}

model BarberTimeOff {
  id                String            @id @default(uuid()) @db.Uuid
  barberId          String            @db.Uuid
  startAt           DateTime
  endAt             DateTime
  reason            String?           @db.Text
  createdAt         DateTime          @default(now())

  barber            BarberProfile     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startAt, endAt])
  @@map("barber_time_offs")
}